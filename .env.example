# --- LLM Provider ---
# "groq" = real answers via Groq API
# "mock" = no API key needed, returns top retrieved chunk instead of a generated answer
LLM_PROVIDER=groq

GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-8b-instant

# --- Embedding model (downloads once, ~80MB, then cached locally) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Knowledge base file ---
DATA_FILE=data/aiseason-document.txt

# --- Chunking sizes (characters) ---
FIXED_CHUNK_SIZE=500
SENTENCE_CHUNK_SIZE=500
RECURSIVE_CHUNK_SIZE=500
RECURSIVE_CHUNK_OVERLAP=80

# --- Retrieval ---
TOP_K=3
